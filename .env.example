# ─── 서버 기본 설정 ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── 보안 ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_key_32chars_min

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ─── AI API 키 (핵심) ─────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey (AIza로 시작)
AI_GEMINI_API_KEY=
# Claude: https://console.anthropic.com/ (sk-ant-로 시작)
AI_CLAUDE_API_KEY=
# LiteLLM 프록시 URL (선택 — 자체 호스팅 시)
AI_LITELLM_URL=

# ─── Google Cloud Vision (OCR fallback, 선택) ─────────────────
GOOGLE_CLOUD_VISION_API_KEY=

# ─── Cloudflare 터널 (선택) ──────────────────────────────────
TUNNEL_ENABLED=false

# ─── 이메일 알림 (선택) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# ─── 웹훅 알림 (선택) ────────────────────────────────────────
NOTIFY_WEBHOOK_URL=
